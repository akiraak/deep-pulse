{
  "name": "deep-pulse",
  "version": "0.1.0",
  "description": "ニュース収集と深い考察による記事生成ツール",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "serve": "tsx src/index.ts",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "keywords": [
    "news",
    "analysis",
    "article-generation"
  ],
  "license": "MIT",
  "dependencies": {
    "marked": "^17.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
